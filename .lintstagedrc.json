{
  "control-plane-ui/src/**/*.{ts,tsx}": [
    "bash -c 'cd control-plane-ui && npx eslint --no-error-on-unmatched-pattern \"$@\"' _",
    "bash -c 'cd control-plane-ui && npx prettier --check \"$@\"' _"
  ],
  "portal/src/**/*.{ts,tsx}": [
    "bash -c 'cd portal && npx eslint --no-error-on-unmatched-pattern \"$@\"' _",
    "bash -c 'cd portal && npx prettier --check \"$@\"' _"
  ],
  "control-plane-api/src/**/*.py": [
    "bash -c 'cd control-plane-api && python3 -m ruff check \"$@\"' _"
  ],
  "mcp-gateway/src/**/*.py": [
    "bash -c 'cd mcp-gateway && python3 -m ruff check \"$@\"' _"
  ]
}
