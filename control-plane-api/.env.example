# Control Plane API — Environment Configuration
# Copy this file to .env and fill in your values
# See src/config.py for all available settings

# ── Core ─────────────────────────────────────────────────────────────────────
# ENVIRONMENT=dev                         # dev | staging | production
# DEBUG=false
# BASE_DOMAIN=gostoa.dev                  # Used to construct default URLs

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://stoa:stoa@localhost:5432/stoa
# DATABASE_POOL_SIZE=5
# DATABASE_MAX_OVERFLOW=10

# ── Keycloak Authentication ──────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8280
KEYCLOAK_REALM=stoa
KEYCLOAK_CLIENT_ID=control-plane-api
KEYCLOAK_CLIENT_SECRET=
# KEYCLOAK_VERIFY_SSL=true

# Keycloak Admin API (service account management)
# KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
# KEYCLOAK_ADMIN_CLIENT_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Kafka / Redpanda ────────────────────────────────────────────────────────
# KAFKA_ENABLED=true
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# ── OpenSearch ───────────────────────────────────────────────────────────────
# OPENSEARCH_HOST=https://localhost:9200
# OPENSEARCH_USER=admin
# OPENSEARCH_PASSWORD=
# OPENSEARCH_VERIFY_CERTS=true

# ── Gateway Integration ──────────────────────────────────────────────────────
# GATEWAY_URL=https://gateway.gostoa.dev
# GATEWAY_ADMIN_USER=Administrator
# GATEWAY_ADMIN_PASSWORD=
# MCP_GATEWAY_URL=http://localhost:8080

# Gateway Auto-Registration (ADR-028)
# GATEWAY_API_KEYS=                       # Comma-separated valid API keys
# GATEWAY_HEARTBEAT_TIMEOUT_SECONDS=90
# GATEWAY_HEALTH_CHECK_INTERVAL_SECONDS=30

# ── Backend API Encryption (CAB-1188 BYOK) ──────────────────────────────────
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# BACKEND_ENCRYPTION_KEY=

# ── Sync Engine ──────────────────────────────────────────────────────────────
# SYNC_ENGINE_ENABLED=true
# SYNC_ENGINE_INTERVAL_SECONDS=300
# SYNC_ENGINE_MAX_CONCURRENT=5
# SYNC_ENGINE_RETRY_MAX=3

# ── Rate Limiting ────────────────────────────────────────────────────────────
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_SECONDS=60

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT=json                         # json | text

# ── Audit ────────────────────────────────────────────────────────────────────
# AUDIT_ENABLED=true
# AUDIT_BUFFER_SIZE=100
# AUDIT_FLUSH_INTERVAL=5.0

# ── Observability URLs ───────────────────────────────────────────────────────
# ARGOCD_URL=https://argocd.gostoa.dev
# GRAFANA_URL=https://grafana.gostoa.dev
# PROMETHEUS_URL=https://prometheus.gostoa.dev

# ── GitLab (optional, for UAC catalog sync) ──────────────────────────────────
# GITLAB_URL=https://gitlab.com
# GITLAB_TOKEN=
# GITLAB_PROJECT_ID=
