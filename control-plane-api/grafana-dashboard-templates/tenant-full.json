{
  "annotations": { "list": [] },
  "description": "Enterprise tenant dashboard — SLO status, error budget, latency, traces, logs, tool breakdown",
  "editable": false,
  "graphTooltip": 2,
  "id": null,
  "links": [
    {
      "title": "Trace Explorer",
      "url": "/explore?orgId=1&left={\"datasource\":\"tempo\",\"queries\":[{\"queryType\":\"traceqlSearch\",\"filters\":[{\"id\":\"tenant_id\",\"tag\":\"tenant_id\",\"operator\":\"=\",\"value\":[\"$tenant_id\"]}]}]}",
      "icon": "bolt",
      "type": "link",
      "targetBlank": true
    },
    {
      "title": "Log Explorer",
      "url": "/explore?orgId=1&left={\"datasource\":\"loki\",\"queries\":[{\"expr\":\"{tenant_id=\\\"$tenant_id\\\"}\"}]}",
      "icon": "file-alt",
      "type": "link",
      "targetBlank": true
    }
  ],
  "templating": {
    "list": [
      {
        "name": "tenant_id",
        "type": "constant",
        "hide": 2,
        "current": { "text": "TENANT_ID", "value": "TENANT_ID" },
        "options": [{ "text": "TENANT_ID", "value": "TENANT_ID", "selected": true }]
      }
    ]
  },
  "panels": [
    {
      "title": "SLO Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Error Budget Remaining",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "slo:error_budget:remaining_ratio{tier=\"enterprise\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.05 },
              { "color": "yellow", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "title": "Availability (30d)",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "slo:composite_availability:ratio30d{tier=\"enterprise\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.995 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      }
    },
    {
      "title": "Budget (min remaining)",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 6, "y": 4 },
      "targets": [
        {
          "expr": "slo:error_budget:remaining_ratio{tier=\"enterprise\"} * 0.001 * 30 * 24 * 60",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "m", "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "green", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "title": "Error Budget Trend",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 14, "x": 10, "y": 1 },
      "targets": [
        {
          "expr": "slo:error_budget:remaining_ratio{tier=\"enterprise\"}",
          "legendFormat": "Budget Remaining",
          "refId": "A"
        },
        { "expr": "0.25", "legendFormat": "Warning (25%)", "refId": "B" },
        { "expr": "0.05", "legendFormat": "Critical (5%)", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Warning (25%)" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10,10] } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Critical (5%)" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10,10] } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      }
    },
    {
      "title": "Traffic & Errors",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "title": "API Call Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(stoa_control_plane_http_requests_total{tenant_id=\"$tenant_id\"}[5m]))",
          "legendFormat": "Requests/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(stoa_control_plane_http_requests_total{tenant_id=\"$tenant_id\", status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      }
    },
    {
      "title": "Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(stoa_control_plane_http_request_duration_seconds_bucket{tenant_id=\"$tenant_id\"}[5m])))",
          "legendFormat": "p50", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(stoa_control_plane_http_request_duration_seconds_bucket{tenant_id=\"$tenant_id\"}[5m])))",
          "legendFormat": "p95", "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(stoa_control_plane_http_request_duration_seconds_bucket{tenant_id=\"$tenant_id\"}[5m])))",
          "legendFormat": "p99", "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "title": "Tool Analytics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false
    },
    {
      "title": "Tool Call Rate by Tool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "targets": [
        {
          "expr": "sum by (tool) (rate(stoa_mcp_tool_invocations_total{tenant_id=\"$tenant_id\"}[5m]))",
          "legendFormat": "{{ tool }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      }
    },
    {
      "title": "Tool Breakdown (30d)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "targets": [
        {
          "expr": "sum by (tool) (increase(stoa_mcp_tool_invocations_total{tenant_id=\"$tenant_id\"}[30d]))",
          "legendFormat": "{{ tool }}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }]
      }
    },
    {
      "title": "Daily Volume (30d)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false
    },
    {
      "title": "Daily Request Volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "sum(increase(stoa_control_plane_http_requests_total{tenant_id=\"$tenant_id\"}[1d]))",
          "legendFormat": "Requests", "refId": "A",
          "interval": "1d"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 50 } }
      }
    },
    {
      "title": "Daily Tool Calls",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "targets": [
        {
          "expr": "sum(increase(stoa_mcp_tool_invocations_total{tenant_id=\"$tenant_id\"}[1d]))",
          "legendFormat": "Tool Calls", "refId": "A",
          "interval": "1d"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 50 } }
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["stoa", "tenant", "enterprise", "slo"],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Tenant Overview",
  "uid": "",
  "version": 1
}
