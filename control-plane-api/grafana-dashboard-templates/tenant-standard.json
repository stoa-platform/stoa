{
  "annotations": { "list": [] },
  "description": "Standard tenant dashboard — call rate, error rate, latency percentiles, daily trend, tool breakdown",
  "editable": false,
  "graphTooltip": 2,
  "id": null,
  "links": [],
  "templating": {
    "list": [
      {
        "name": "tenant_id",
        "type": "constant",
        "hide": 2,
        "current": { "text": "TENANT_ID", "value": "TENANT_ID" },
        "options": [{ "text": "TENANT_ID", "value": "TENANT_ID", "selected": true }]
      }
    ]
  },
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "API Call Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(stoa_control_plane_http_requests_total{tenant_id=\"$tenant_id\"}[5m]))",
          "legendFormat": "Requests/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      }
    },
    {
      "title": "Error Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(stoa_control_plane_http_requests_total{tenant_id=\"$tenant_id\", status_code=~\"5..\"}[1h])) / sum(rate(stoa_control_plane_http_requests_total{tenant_id=\"$tenant_id\"}[1h])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Total Requests (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(stoa_control_plane_http_requests_total{tenant_id=\"$tenant_id\"}[24h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 }
      }
    },
    {
      "title": "Tool Calls (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "expr": "sum(increase(stoa_mcp_tool_invocations_total{tenant_id=\"$tenant_id\"}[24h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 }
      }
    },
    {
      "title": "Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(stoa_control_plane_http_request_duration_seconds_bucket{tenant_id=\"$tenant_id\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(stoa_control_plane_http_request_duration_seconds_bucket{tenant_id=\"$tenant_id\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(stoa_control_plane_http_request_duration_seconds_bucket{tenant_id=\"$tenant_id\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "title": "Daily Trend (30d)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false
    },
    {
      "title": "Daily Request Volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(increase(stoa_control_plane_http_requests_total{tenant_id=\"$tenant_id\"}[1d]))",
          "legendFormat": "Requests",
          "refId": "A",
          "interval": "1d"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 50 } }
      }
    },
    {
      "title": "Tool Breakdown",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sum by (tool) (increase(stoa_mcp_tool_invocations_total{tenant_id=\"$tenant_id\"}[30d]))",
          "legendFormat": "{{ tool }}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }]
      }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["stoa", "tenant", "standard"],
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Tenant Overview",
  "uid": "",
  "version": 1
}
