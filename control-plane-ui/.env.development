# Console UI — Local development (loaded automatically by Vite in dev mode)
# Matches docker-compose defaults from deploy/docker-compose/

VITE_ENVIRONMENT=dev
VITE_API_URL=http://localhost:8000
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=stoa
VITE_KEYCLOAK_CLIENT_ID=control-plane-ui
VITE_MCP_GATEWAY_URL=http://localhost:8081
VITE_GRAFANA_URL=http://localhost:3001
VITE_PROMETHEUS_URL=http://localhost:9090
VITE_LOGS_URL=http://localhost:5601
VITE_ENABLE_DEBUG=true
