# =============================================================================
# STOA Platform Quick Start - Environment Configuration
# =============================================================================
# Copy this file to .env and customize as needed:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=stoa
POSTGRES_PASSWORD=stoa-quickstart-2045
POSTGRES_DB=stoa_platform

# -----------------------------------------------------------------------------
# Keycloak (Authentication)
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# Grafana (Dashboards)
# -----------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# -----------------------------------------------------------------------------
# Service Ports
# Change these if you have port conflicts on your machine
# -----------------------------------------------------------------------------
PORT_DB=5432
PORT_KEYCLOAK=8080
PORT_API=8000
PORT_CONSOLE=3000
PORT_PORTAL=3002
PORT_GATEWAY=8081
PORT_PROXY=80
PORT_PROMETHEUS=9090
PORT_GRAFANA=3001
PORT_LOKI=3100
PORT_OPENSEARCH=9200
PORT_OPENSEARCH_DASHBOARDS=5601

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Docker Compose Settings
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=stoa-quickstart

# -----------------------------------------------------------------------------
# Monitoring OIDC (CAB-1103 Phase 6B)
# Required for Grafana SSO and Prometheus oauth2-proxy
# Get these from Keycloak after running deploy/scripts/setup-observability-oidc.sh
# -----------------------------------------------------------------------------
GRAFANA_OIDC_CLIENT_SECRET=observability-dev-secret
OAUTH2_PROXY_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_SECRET=
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Additional Service Ports (CAB-1103 Phase 6B)
# -----------------------------------------------------------------------------
PORT_OAUTH2_PROXY=4180
PORT_ALERTMANAGER=9093

# -----------------------------------------------------------------------------
# Federation Demo (ADR-026) — activate with: docker compose --profile federation up -d
# -----------------------------------------------------------------------------
PORT_FEDERATION_GATEWAY=9000
PORT_LDAP=1389
LDAP_ADMIN_PASSWORD=admin-password
