# =============================================================================
# Vault Agent Template — Control Plane API Secrets
# =============================================================================
# Rendered by Vault Agent into /vault/rendered/api-secrets.env
# Consumed by control-plane-api via volume mount.
# Auto-refreshed when secrets change in Vault.
# =============================================================================

# --- KV v2: Database credentials (static, from seed) ---
{{- with secret "stoa/data/k8s/control-plane-api" }}
DATABASE_URL={{ .Data.data.DATABASE_URL }}
KEYCLOAK_ADMIN_PASSWORD={{ .Data.data.KEYCLOAK_ADMIN_PASSWORD }}
KEYCLOAK_CLIENT_SECRET={{ .Data.data.KEYCLOAK_CLIENT_SECRET }}
{{- end }}

# --- KV v2: Keycloak shared ---
{{- with secret "stoa/data/shared/keycloak" }}
KEYCLOAK_URL={{ .Data.data.KEYCLOAK_URL }}
{{- end }}

# --- Dynamic: PostgreSQL credentials (auto-rotated by lease) ---
{{- with secret "database/creds/api-role" }}
VAULT_DB_USERNAME={{ .Data.username }}
VAULT_DB_PASSWORD={{ .Data.password }}
VAULT_DB_LEASE_ID={{ .LeaseID }}
VAULT_DB_LEASE_TTL={{ .LeaseDuration }}
{{- end }}

# --- Metadata ---
VAULT_AGENT_RENDERED=true
VAULT_AGENT_RENDERED_AT={{ timestamp }}
