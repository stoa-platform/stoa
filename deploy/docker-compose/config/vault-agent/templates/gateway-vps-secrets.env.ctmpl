# =============================================================================
# Vault Agent Template — Gateway VPS Secrets
# =============================================================================
# Simulates a VPS Vault Agent for gateway services.
# Rendered by Vault Agent into /vault/rendered/gateway-vps-secrets.env
# =============================================================================

# --- KV v2: Gateway secrets ---
{{- with secret "stoa/data/k8s/gateway" }}
STOA_CONTROL_PLANE_API_KEY={{ .Data.data.STOA_CONTROL_PLANE_API_KEY }}
STOA_KEYCLOAK_CLIENT_SECRET={{ .Data.data.STOA_KEYCLOAK_CLIENT_SECRET }}
{{- end }}

# --- Metadata ---
VAULT_AGENT_RENDERED=true
VAULT_AGENT_RENDERED_AT={{ timestamp }}
