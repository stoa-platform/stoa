{
  "index_patterns": ["stoa-gw-*"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "gateway_type": {
          "type": "keyword"
        },
        "gateway_id": {
          "type": "keyword"
        },
        "tenant_id": {
          "type": "keyword"
        },
        "method": {
          "type": "keyword"
        },
        "path": {
          "type": "text",
          "fields": { "keyword": { "type": "keyword" } }
        },
        "status": {
          "type": "integer"
        },
        "latency_ms": {
          "type": "float"
        },
        "trace_id": {
          "type": "keyword"
        },
        "request_id": {
          "type": "keyword"
        },
        "user_agent": {
          "type": "text"
        },
        "source_ip": {
          "type": "ip"
        },
        "request_body": {
          "type": "text",
          "_meta": { "pii": true }
        },
        "response_body": {
          "type": "text",
          "_meta": { "pii": true }
        },
        "auth_token": {
          "type": "keyword",
          "_meta": { "pii": true }
        },
        "consumer_id": {
          "type": "keyword"
        },
        "api_name": {
          "type": "keyword"
        },
        "environment": {
          "type": "keyword"
        },
        "tags": {
          "type": "keyword"
        }
      },
      "_meta": {
        "pii_fields": ["request_body", "response_body", "auth_token"],
        "description": "Gateway telemetry logs with PII tagging for GDPR compliance"
      }
    }
  },
  "priority": 200,
  "version": 1,
  "_meta": {
    "description": "STOA Platform - Gateway Telemetry Logs (multi-gateway, per-tenant)",
    "managed_by": "stoa-telemetry-service",
    "cab_ticket": "CAB-1684"
  }
}
