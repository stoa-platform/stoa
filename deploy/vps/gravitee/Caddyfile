# Gravitee VPS — TLS termination via Caddy (Let's Encrypt)
# Ports: 8083 (mgmt API), 8082 (proxy), 9100 (stoa-connect), 9200 (stoa-link)

gravitee.gostoa.dev {
	reverse_proxy localhost:8083
}

connect-gravitee.gostoa.dev {
	reverse_proxy localhost:8090
}

link-gravitee.gostoa.dev {
	reverse_proxy localhost:9200
}
