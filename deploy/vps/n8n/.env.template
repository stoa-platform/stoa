# n8n Self-Hosted — Environment Variables
# Copy to .env and fill in values
#
# Generate encryption key: openssl rand -hex 32
# Generate postgres password: openssl rand -base64 24
# Generate HMAC secret: openssl rand -hex 32

# --- Core ---
POSTGRES_PASSWORD=
N8N_ENCRYPTION_KEY=

# --- Workflow secrets (replaces n8n Variables — Enterprise-only) ---
# Used by workflows via $env.VARIABLE_NAME
APPROVE_HMAC_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_ALLOWED_USERS=
SLACK_ADMIN_USERS=
