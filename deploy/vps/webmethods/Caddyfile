# webMethods VPS — TLS termination via Caddy (Let's Encrypt)
# gateway.gostoa.dev already has TLS? If not, add it here.
# Ports: 5555 (admin), 9072 (UI), 9100 (stoa-connect), 9200 (stoa-link)

webmethods.gostoa.dev {
	reverse_proxy localhost:5555
}

connect-webmethods.gostoa.dev {
	reverse_proxy localhost:8090
}

link-webmethods.gostoa.dev {
	reverse_proxy localhost:9200
}
