{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Real-time service graph showing call flow across STOA Gateway, Link, and Connect. CAB-1842.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["stoa", "gateway"],
      "targetBlank": true,
      "title": "Gateway Unified",
      "type": "dashboards"
    },
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["stoa", "traces"],
      "targetBlank": true,
      "title": "Request Journey",
      "type": "dashboards"
    }
  ],
  "liveNow": true,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Service Topology",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "${tempo_datasource}" },
      "description": "Auto-generated service graph from OTLP traces. Nodes represent services (colored by deployment mode), edges show call relationships with RED metrics.\n\nGateway (edge-mcp) = blue | Link (sidecar) = green | Connect = orange | Backend = grey",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "options": {},
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${tempo_datasource}" },
          "queryType": "serviceMap",
          "serviceMapQuery": "{resource.service.name=~\"stoa-.*\"}",
          "refId": "A"
        }
      ],
      "title": "STOA Call Flow — Live Service Graph",
      "type": "nodeGraph"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 3,
      "title": "RED Metrics by Deployment Mode",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Request rate per deployment mode (edge-mcp, sidecar, connect)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "req/s",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "edge-mcp" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#3274D9", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "sidecar" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#56A64B", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "connect" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "sum by (stoa_deployment_mode) (rate(traces_service_graph_request_total{server=\"stoa-gateway\"}[$__rate_interval]))",
          "legendFormat": "{{ stoa_deployment_mode }}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Mode",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Error rate per deployment mode",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "%",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "100 * sum by (stoa_deployment_mode) (rate(traces_service_graph_request_failed_total{server=\"stoa-gateway\"}[$__rate_interval])) / sum by (stoa_deployment_mode) (rate(traces_service_graph_request_total{server=\"stoa-gateway\"}[$__rate_interval]))",
          "legendFormat": "{{ stoa_deployment_mode }}",
          "refId": "A"
        }
      ],
      "title": "Error Rate by Mode",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "P95 latency per deployment mode",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "latency",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2.0 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "id": 6,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, stoa_deployment_mode) (rate(traces_service_graph_request_server_seconds_bucket{server=\"stoa-gateway\"}[$__rate_interval])))",
          "legendFormat": "p95 {{ stoa_deployment_mode }}",
          "refId": "A"
        }
      ],
      "title": "P95 Latency by Mode",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 7,
      "title": "Policy Waterfall",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Breakdown of policies applied per request. Shows which policy middleware steps are active and their relative frequency. Requires STOA_DETAILED_TRACING=true for per-policy spans.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 8,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{span_name=~\"policy\", service=\"stoa-gateway\"}[$__rate_interval]))",
          "legendFormat": "{{ span_name }}",
          "refId": "A"
        }
      ],
      "title": "Policy Execution Frequency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
      "description": "Average duration of each policy middleware step. Helps identify slow policies.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "none",
            "lineWidth": 1
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 9,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${prometheus_datasource}" },
          "expr": "1000 * sum by (span_name) (rate(traces_spanmetrics_latency_sum{span_name=~\"policy\", service=\"stoa-gateway\"}[$__rate_interval])) / sum by (span_name) (rate(traces_spanmetrics_latency_count{span_name=~\"policy\", service=\"stoa-gateway\"}[$__rate_interval]))",
          "legendFormat": "{{ span_name }}",
          "refId": "A"
        }
      ],
      "title": "Policy Avg Duration (ms)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 10,
      "title": "Recent Traces",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "${tempo_datasource}" },
      "description": "Most recent traces filtered by tenant and deployment mode. Click a trace ID to see the full waterfall.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 34 },
      "id": 11,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Start time", "desc": true }] },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "${tempo_datasource}" },
          "queryType": "nativeSearch",
          "serviceName": "stoa-gateway",
          "search": "stoa.deployment_mode=$deployment_mode",
          "limit": 30,
          "refId": "A"
        }
      ],
      "title": "Recent Traces",
      "type": "table"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["stoa", "call-flow", "service-graph", "observability"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "name": "prometheus_datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": { "selected": false, "text": "Tempo", "value": "tempo" },
        "hide": 0,
        "includeAll": false,
        "label": "Tempo",
        "name": "tempo_datasource",
        "options": [],
        "query": "tempo",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "definition": "label_values(stoa_http_requests_total, tenant)",
        "hide": 0,
        "includeAll": true,
        "label": "Tenant",
        "multi": true,
        "name": "tenant",
        "options": [],
        "query": { "query": "label_values(stoa_http_requests_total, tenant)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "label": "Deployment Mode",
        "multi": false,
        "name": "deployment_mode",
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "edge-mcp", "value": "edge-mcp" },
          { "selected": false, "text": "sidecar", "value": "sidecar" },
          { "selected": false, "text": "connect", "value": "connect" },
          { "selected": false, "text": "proxy", "value": "proxy" },
          { "selected": false, "text": "shadow", "value": "shadow" }
        ],
        "query": "edge-mcp,sidecar,connect,proxy,shadow",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "STOA Call Flow",
  "uid": "stoa-call-flow",
  "version": 1
}
