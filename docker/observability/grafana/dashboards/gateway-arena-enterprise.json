      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 25},
      "id": 30,
      "options": {"legend": {"calcs": ["lastNotNull", "min", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {
          "expr": "gateway_arena_enterprise_score{gateway=~\"$gateway\"}",
          "legendFormat": "{{gateway}}",
          "refId": "A"
        },
        {
          "expr": "gateway_arena_enterprise_score_ci_upper{gateway=~\"$gateway\"}",
          "legendFormat": "{{gateway}} CI95 Upper",
          "refId": "B"
        },
        {
          "expr": "gateway_arena_enterprise_score_ci_lower{gateway=~\"$gateway\"}",
          "legendFormat": "{{gateway}} CI95 Lower",
          "refId": "C"
        }
      ],
      "title": "Enterprise Readiness Index — Trend",
      "type": "timeseries"
    }
