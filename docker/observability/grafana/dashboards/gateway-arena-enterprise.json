        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 19},
      "id": 20,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [
        {
          "expr": "gateway_arena_enterprise_dimension{gateway=~\"$gateway\",dimension=\"mcp_discovery\"}",
          "legendFormat": "{{gateway}}",
          "refId": "A"
        }
      ],
      "title": "MCP Discovery",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "MCP Tool Execution dimension. Measures POST /mcp/tools/list JSON-RPC performance (p95 < 500ms).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 80}
            ]
          },
          "min": 0,
          "max": 100,
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 19},
      "id": 21,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [
        {
          "expr": "gateway_arena_enterprise_dimension{gateway=~\"$gateway\",dimension=\"mcp_toolcall\"}",
          "legendFormat": "{{gateway}}",
          "refId": "A"
        }
      ],
      "title": "MCP Tool Execution",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "P95 latency per enterprise dimension (seconds). Lower is better.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Latency (s)",
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "min": 0,
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 12, "x": 12, "y": 19},
      "id": 22,
      "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single", "sort": "none"}},
      "targets": [
        {
          "expr": "gateway_arena_enterprise_latency_p95{gateway=~\"$gateway\",dimension=~\"$dimension\"}",
          "legendFormat": "{{gateway}} — {{dimension}}",
          "refId": "A"
        }
      ],
      "title": "P95 Latency by Dimension",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24},
      "id": 103,
      "panels": [],
      "title": "Score Trend",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Enterprise Readiness Index over time with CI95 confidence band.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Enterprise Score",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "min": 0,
          "max": 100,
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": ".*CI.*"},
            "properties": [
              {"id": "custom.lineWidth", "value": 0},
              {"id": "custom.fillOpacity", "value": 20},
              {"id": "custom.fillBelowTo", "value": "ci_lower"}
            ]
