    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Per-dimension scores for each gateway across 20 dimensions. 0 = feature not implemented. Color: red < 20, yellow < 50, green >= 80.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"align": "auto", "cellOptions": {"type": "color-background"}, "inspect": false},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 20},
              {"color": "yellow", "value": 50},
              {"color": "green", "value": 80}
            ]
          },
          "unit": "none",
          "decimals": 1,
          "min": 0,
          "max": 100
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "dimension"},
            "properties": [
              {"id": "custom.cellOptions", "value": {"type": "auto"}},
              {"id": "custom.width", "value": 180}
            ]
          }
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 8},
      "id": 10,
      "options": {"showHeader": true, "sortBy": [{"desc": true, "displayName": "dimension"}]},
      "targets": [
        {
          "expr": "gateway_arena_enterprise_dimension{gateway=~\"$gateway\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Dimension Scores (per gateway)",
      "transformations": [
        {"id": "groupBy", "options": {"fields": {"dimension": {"aggregations": [], "operation": "groupby"}, "gateway": {"aggregations": [], "operation": "groupby"}, "Value": {"aggregations": ["lastNotNull"], "operation": "aggregate"}}}},
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "instance": true, "job": true}, "indexByName": {}, "renameByName": {"Value (lastNotNull)": "Score"}}},
        {"id": "sortBy", "options": {"fields": {}, "sort": [{"field": "dimension"}]}}
      ],
      "type": "table"
    },
