      "type": "stat",
      "targets": [
        {
          "expr": "hegemon_queue_depth",
          "legendFormat": "Active Dispatches"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] },
          "mappings": [
            { "options": { "0": { "text": "Active", "color": "green" }, "1": { "text": "PAUSED", "color": "orange" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "id": 4,
      "options": {
        "colorMode": "background",
