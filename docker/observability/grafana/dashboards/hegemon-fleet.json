{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "IDLE", "color": "green" }, "1": { "text": "BUSY", "color": "blue" }, "2": { "text": "UNHEALTHY", "color": "red" }, "3": { "text": "PAUSED", "color": "orange" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Worker Fleet Status",
      "type": "stat",
      "targets": [
        {
          "expr": "hegemon_worker_status",
          "legendFormat": "{{worker}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Health Failures (Consecutive)",
      "type": "stat",
      "targets": [
        {
          "expr": "hegemon_worker_health_fail_count",
          "legendFormat": "{{worker}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 5 }] }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "id": 3,
      "options": {
        "colorMode": "background",
