{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["ai-factory"],
      "targetBlank": true,
      "title": "AI Factory Dashboards",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "title": "LLM Token Overview",
      "type": "row"
    },
    {
      "title": "Total Tokens Processed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10000 },
              { "color": "yellow", "value": 100000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(stoa_token_budget_tokens_total{tenant=~\"$project\"})",
          "legendFormat": "Tokens",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Estimated Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(gateway_llm_cost_total)",
          "legendFormat": "Cost",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Cache Hit Ratio",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(stoa_mcp_tools_calls_total{tenant=~\"$project\", status=\"cache_hit\"}) / clamp_min(sum(stoa_mcp_tools_calls_total{tenant=~\"$project\"}), 1)",
          "legendFormat": "Hit Ratio",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Active Projects",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "count(count by (tenant) (stoa_token_budget_tokens_total))",
          "legendFormat": "Projects",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Tokens Consumed per Project",
      "description": "Total tokens processed by each project/tenant, split by direction (input/output)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "stacking": "normal",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" },
        "orientation": "horizontal",
        "barWidth": 0.7
      },
      "targets": [
        {
          "expr": "sum by (tenant, direction) (stoa_token_budget_tokens_total{tenant=~\"$project\"})",
          "legendFormat": "{{tenant}} — {{direction}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "title": "Token Throughput Over Time",
      "description": "Token rate per project over time (tokens/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (tenant) (rate(stoa_token_budget_tokens_total{tenant=~\"$project\"}[5m]))",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "title": "Quota & Cost",
      "type": "row"
    },
    {
      "title": "Quota Remaining per Project",
      "description": "Remaining quota for each consumer/project. Lower values indicate approaching limits.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 20 },
              { "color": "green", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "stoa_quota_remaining{consumer=~\"$project\"}",
          "legendFormat": "{{consumer}} ({{period}})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Estimated Cost per Project",
      "description": "Estimated LLM cost breakdown by provider and model",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "textMode": "value_and_name",
        "colorMode": "background",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "sum by (provider) (gateway_llm_cost_total)",
          "legendFormat": "{{provider}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "title": "Cache Performance",
      "type": "row"
    },
    {
      "title": "Cache Hit vs Miss",
      "description": "Proportion of tool calls served from semantic cache vs backend execution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Cache Hits" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "API Calls" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          }
        ]
      },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "sum(stoa_mcp_tools_calls_total{tenant=~\"$project\", status=\"cache_hit\"})",
          "legendFormat": "Cache Hits",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "sum(stoa_mcp_tools_calls_total{tenant=~\"$project\", status!=\"cache_hit\"})",
          "legendFormat": "API Calls",
          "refId": "B",
          "instant": true
        }
      ]
    },
    {
      "title": "Cache Hit Rate Over Time",
      "description": "Cache hit ratio trend — higher is better (reduces LLM API costs)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "sum(rate(stoa_mcp_tools_calls_total{tenant=~\"$project\", status=\"cache_hit\"}[5m])) / clamp_min(sum(rate(stoa_mcp_tools_calls_total{tenant=~\"$project\"}[5m])), 0.001)",
          "legendFormat": "Hit Rate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Budget Exceeded Events",
      "description": "Token budget exceeded events per project — indicates quota enforcement",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2,
            "drawStyle": "bars"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (tenant) (increase(stoa_token_budget_exceeded_total{tenant=~\"$project\"}[1h]))",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["ai-factory", "llm", "tokens", "cost", "stoa"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(stoa_token_budget_tokens_total, tenant)",
        "hide": 0,
        "includeAll": true,
        "label": "Project / Tenant",
        "multi": true,
        "name": "project",
        "query": { "query": "label_values(stoa_token_budget_tokens_total, tenant)", "refId": "project" },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "title": "LLM Token Tracking — Per Project",
  "uid": "llm-token-tracking"
}
