{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Arena Layer 2 — Platform Continuous Verification (3 CUJs, every 15 min)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["stoa"],
      "targetBlank": true,
      "title": "STOA Dashboards",
      "type": "dashboards"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "Platform Health — Overall",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Overall platform health: CUJs passed / total",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 2},
              {"color": "green", "value": 3}
            ]
          },
          "min": 0,
          "max": 3,
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 4, "x": 0, "y": 1},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name"},
      "title": "CUJs Passing",
      "targets": [
        {
          "expr": "platform_verify_overall_score",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Time since last verification run",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 900},
              {"color": "red", "value": 1200}
            ]
          },
          "unit": "s",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 4, "x": 4, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name"},
      "title": "Last Run Age",
      "targets": [
        {
          "expr": "time() - platform_verify_last_run_timestamp",
          "legendFormat": "Seconds ago",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Platform health ratio over time (1.0 = all CUJs passing)",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "Health Ratio",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {"mode": "none"}
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.66},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 16, "x": 8, "y": 1},
      "id": 3,
      "options": {"legend": {"calcs": ["lastNotNull", "min"], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}},
      "title": "Platform Health Over Time",
      "targets": [
        {
          "expr": "platform:verify_health:ratio",
          "legendFormat": "Health Ratio",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 7},
      "id": 200,
      "panels": [],
      "title": "CUJ Status — Individual Journeys",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "API Health Chain: /health on API + Gateway + Keycloak",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "red", "text": "FAIL"}}, "type": "value"},
            {"options": {"1": {"color": "green", "text": "PASS"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 8},
      "id": 10,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value"},
      "title": "CUJ 1: API Health Chain",
      "targets": [
        {
          "expr": "platform_verify_cuj_status{cuj=\"api_health\"}",
          "legendFormat": "API Health",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Auth Flow: OIDC token + authenticated API call",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "red", "text": "FAIL"}}, "type": "value"},
            {"options": {"1": {"color": "green", "text": "PASS"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 8},
      "id": 11,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value"},
      "title": "CUJ 2: Auth Flow",
      "targets": [
        {
          "expr": "platform_verify_cuj_status{cuj=\"auth_flow\"}",
          "legendFormat": "Auth Flow",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "MCP Discovery: /mcp/capabilities + /mcp/tools/list",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "red", "text": "FAIL"}}, "type": "value"},
            {"options": {"1": {"color": "green", "text": "PASS"}}, "type": "value"}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 8},
      "id": 12,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value"},
      "title": "CUJ 3: MCP Discovery",
      "targets": [
        {
          "expr": "platform_verify_cuj_status{cuj=\"mcp_discovery\"}",
          "legendFormat": "MCP Discovery",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 12},
      "id": 300,
      "panels": [],
      "title": "CUJ Latency — Response Times",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "CUJ execution duration over time",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "Duration",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {"mode": "none"},
            "thresholdsStyle": {"mode": "dashed"}
          },
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 3}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 13},
      "id": 20,
      "options": {"legend": {"calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}},
      "title": "CUJ Duration Over Time",
      "targets": [
        {
          "expr": "platform_verify_cuj_duration_seconds",
          "legendFormat": "{{ cuj }}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 21},
      "id": 400,
      "panels": [],
      "title": "CUJ Availability — 1h Rolling",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Per-CUJ availability over the last hour (% of runs passing)",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "green", "value": 0.9}
            ]
          },
          "unit": "percentunit",
          "decimals": 0,
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 22},
      "id": 30,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name"},
      "title": "CUJ 1h Availability",
      "targets": [
        {
          "expr": "platform:cuj_availability_1h:ratio",
          "legendFormat": "{{ cuj }}",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Rolling 1h availability per CUJ over time",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisLabel": "Availability",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"mode": "none"}
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 16, "x": 8, "y": 22},
      "id": 31,
      "options": {"legend": {"calcs": ["lastNotNull", "min"], "displayMode": "table", "placement": "right"}, "tooltip": {"mode": "multi"}},
      "title": "CUJ Availability Over Time (1h Rolling)",
      "targets": [
        {
          "expr": "platform:cuj_availability_1h:ratio",
          "legendFormat": "{{ cuj }}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["stoa", "platform", "health", "arena", "verify"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "Prometheus", "value": "prometheus"},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "utc",
  "title": "Platform Health — Arena L2",
  "uid": "platform-health-l2",
  "version": 1
}
