{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Trace a single request across all STOA components using trace_id. CAB-1455 Phase 3.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["stoa", "logs"],
      "targetBlank": true,
      "title": "Logs Explorer",
      "tooltip": "Open STOA Logs Explorer",
      "type": "dashboards",
      "url": ""
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Request Journey",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "description": "All log lines matching the given trace_id, sorted chronologically across all components.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": true
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          },
          {
            "matcher": { "id": "byName", "options": "component" },
            "properties": [{ "id": "custom.width", "value": 160 }]
          },
          {
            "matcher": { "id": "byName", "options": "level" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "error": { "color": "red", "index": 0, "text": "ERROR" } } },
                  { "type": "value", "options": { "warning": { "color": "orange", "index": 1, "text": "WARN" } } },
                  { "type": "value", "options": { "info": { "color": "green", "index": 2, "text": "INFO" } } },
                  { "type": "value", "options": { "debug": { "color": "blue", "index": 3, "text": "DEBUG" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "duration_ms" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              { "id": "unit", "value": "ms" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Line" },
            "properties": [{ "id": "custom.width", "value": 600 }]
          }
        ]
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": true, "fields": "", "reducer": ["count"], "show": true },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Time" }]
      },
      "pluginVersion": "10.2.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "{namespace=~\"$namespace\"} | json | trace_id = `$trace_id` | line_format `{{.message}}`",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Full Request Timeline",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "format": "json",
            "source": "Line"
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 3,
      "title": "Service Participation",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "description": "Number of log entries per component for this trace_id. Shows which services participated in the request.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Log entries",
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1,
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 4,
      "options": {
        "barRadius": 0.05,
        "barWidth": 0.6,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0
      },
      "pluginVersion": "10.2.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum by (component) (count_over_time({namespace=~\"$namespace\"} | json | trace_id = `$trace_id` [$__auto]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log Entries by Component",
      "type": "barchart"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "description": "Distribution of log levels for this trace_id across all components.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
          "mappings": []
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warning" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "debug" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "pluginVersion": "10.2.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum by (level) (count_over_time({namespace=~\"$namespace\"} | json | trace_id = `$trace_id` [$__auto]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log Level Distribution",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 6,
      "title": "Error Details",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "description": "Error and warning logs for this trace_id. Empty if the request completed successfully.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": true
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          },
          {
            "matcher": { "id": "byName", "options": "component" },
            "properties": [{ "id": "custom.width", "value": 160 }]
          },
          {
            "matcher": { "id": "byName", "options": "Line" },
            "properties": [{ "id": "custom.width", "value": 800 }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 25 },
      "id": 7,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": true, "fields": "", "reducer": ["count"], "show": true },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Time" }]
      },
      "pluginVersion": "10.2.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "{namespace=~\"$namespace\"} | json | trace_id = `$trace_id` | level =~ `error|warning`",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Errors & Warnings in Trace",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 8,
      "title": "Latency Breakdown",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "description": "Request duration per component hop. Shows where time is spent in the request chain.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Duration (ms)",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "pluginVersion": "10.2.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "{namespace=~\"$namespace\"} | json | trace_id = `$trace_id` | duration_ms != `` | unwrap duration_ms | __error__=``",
          "legendFormat": "{{component}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Latency per Component Hop",
      "type": "timeseries"
    }
  ],
  "refresh": "",
  "schemaVersion": 38,
  "tags": ["stoa", "logs", "loki", "tracing", "observability"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Loki", "value": "loki" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "loki",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "selected": false, "text": "stoa-system", "value": "stoa-system" },
        "hide": 0,
        "includeAll": true,
        "label": "Namespace",
        "multi": false,
        "name": "namespace",
        "options": [],
        "query": { "label": "namespace", "stream": "{job=~\".+\"}", "type": 1 },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "type": "query",
        "datasource": { "type": "loki", "uid": "${datasource}" }
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "description": "W3C trace_id (32 hex chars) to trace across all components",
        "hide": 0,
        "label": "Trace ID",
        "name": "trace_id",
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "STOA Request Journey",
  "uid": "stoa-request-journey",
  "version": 1,
  "weekStart": ""
}
