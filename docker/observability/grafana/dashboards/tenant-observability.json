{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Per-Tenant Observability - Request metrics, APIs, errors, and audit trail",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["stoa"],
      "targetBlank": true,
      "title": "STOA Dashboards",
      "type": "dashboards"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "Tenant Overview",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Total request rate for selected tenant",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "sum(rate(stoa_http_requests_total{tenant_id=\"$tenant_id\",gateway_type=~\"$gateway_type\"}[5m]))",
          "legendFormat": "Total RPS",
          "refId": "A"
        }
      ],
      "title": "Total Request Rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Error count for tenant",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "sum(rate(stoa_http_requests_total{status=~\"5..\",tenant_id=\"$tenant_id\",gateway_type=~\"$gateway_type\"}[5m]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Average response latency for tenant",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 500}]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["mean"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum(rate(stoa_http_request_duration_seconds_bucket{tenant_id=\"$tenant_id\",gateway_type=~\"$gateway_type\"}[5m])) by (le)) * 1000",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "P50 Latency",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Unique APIs called by this tenant",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "count(count by (api_name) (stoa_http_requests_total{tenant_id=\"$tenant_id\",gateway_type=~\"$gateway_type\"}))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "APIs Used",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 101,
      "panels": [],
      "title": "API Usage & Errors",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Top APIs by request count",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 6},
      "id": 5,
      "options": {
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "showLegend": false},
        "showHeader": true,
        "sortBy": []
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "topk(10, sum by (api_name) (rate(stoa_http_requests_total{tenant_id=\"$tenant_id\",gateway_type=~\"$gateway_type\"}[5m])))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Top 10 APIs",
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Error distribution by HTTP status code",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"hideFrom": {"legend": false, "tooltip": false, "viz": false}},
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 6},
      "id": 6,
      "options": {
        "displayLabels": ["percent"],
        "legend": {"displayMode": "list", "placement": "bottom"},
        "pieType": "pie",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "sum by (status) (rate(stoa_http_requests_total{tenant_id=\"$tenant_id\",gateway_type=~\"$gateway_type\",status=~\"[4-5]..\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Error Breakdown by Status",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 10},
      "id": 102,
      "panels": [],
      "title": "Latency & Activity",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "description": "Latency by API endpoint",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 11},
      "id": 7,
      "options": {
        "colorMode": "value",
        "graphMode": "line",
        "justifyMode": "auto",
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(stoa_http_request_duration_seconds_bucket{tenant_id=\"$tenant_id\",gateway_type=~\"$gateway_type\"}[5m])) by (le, api_name)) * 1000",
          "legendFormat": "{{api_name}}",
          "refId": "A"
        }
      ],
      "title": "P95 Latency by API",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "description": "Audit trail for tenant activity",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 11},
      "id": 8,
      "options": {
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "showLegend": false},
        "showHeader": true,
        "sortBy": []
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "editorMode": "code",
          "expr": "{component=\"stoa-audit\",tenant_id=\"$tenant_id\"} | json | line_format \"{{.timestamp}} {{.event}} {{.resource}}\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Audit Trail (last 100 events)",
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15},
      "id": 103,
      "panels": [],
      "title": "Logs",
      "type": "row"
    },
    {
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "description": "Real-time log stream for selected tenant",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 16},
      "id": 9,
      "options": {
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "showLegend": false},
        "showHeader": true,
        "sortBy": []
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "editorMode": "code",
          "expr": "{tenant_id=\"$tenant_id\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Log Stream",
      "type": "logs"
    }
  ],
