{
  "annotations": {
    "list": []
  },
  "description": "Business analytics — API adoption, tool usage trends, and tenant activity",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total API Requests (24h trend)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "stacking": { "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(stoa_http_requests_total[5m]))",
          "legendFormat": "All requests",
          "refId": "A"
        },
        {
          "expr": "sum(rate(stoa_api_proxy_requests_total[5m]))",
          "legendFormat": "Proxy requests",
          "refId": "B"
        }
      ]
    },
    {
      "title": "MCP Tool Usage by Tool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 40,
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(increase(stoa_mcp_tools_calls_total[1h])) by (tool)",
          "legendFormat": "{{ tool }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requests by Tenant",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "multi" },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "sum(increase(stoa_mcp_tools_calls_total[24h])) by (tenant)",
          "legendFormat": "{{ tenant }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "API Proxy Usage by Backend",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "multi" },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "sum(increase(stoa_api_proxy_requests_total[24h])) by (backend)",
          "legendFormat": "{{ backend }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Quota Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "stacking": { "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "stoa_quota_remaining",
          "legendFormat": "{{ consumer }} ({{ period }})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Rate Limited Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 30,
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(increase(stoa_rate_limit_hits_total[1h])) by (tenant)",
          "legendFormat": "{{ tenant }}",
          "refId": "A"
        },
        {
          "expr": "sum(increase(stoa_api_proxy_rate_limited_total[1h])) by (backend)",
          "legendFormat": "proxy: {{ backend }}",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["stoa", "business", "analytics"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(stoa_mcp_tools_calls_total, tenant)",
        "includeAll": true,
        "multi": true,
        "name": "tenant",
        "query": { "query": "label_values(stoa_mcp_tools_calls_total, tenant)", "refId": "A" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "STOA Business Analytics",
  "uid": "stoa-business-analytics",
  "version": 1
}
