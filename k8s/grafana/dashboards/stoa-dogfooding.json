{
  "annotations": {
    "list": []
  },
  "description": "STOA API Proxy Traffic — per-backend metrics from stoa-gateway (CAB-1730)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Requests per Second (by backend)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "spanNulls": false,
            "stacking": { "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(stoa_api_proxy_requests_total{backend=~\"$backend\"}[5m])) by (backend)",
          "legendFormat": "{{ backend }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Latency P95 (by backend)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "pointSize": 5,
            "spanNulls": false,
            "stacking": { "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(stoa_api_proxy_duration_seconds_bucket{backend=~\"$backend\"}[5m])) by (le, backend))",
          "legendFormat": "{{ backend }} P95",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate (by backend)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "spanNulls": false,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(stoa_api_proxy_requests_total{backend=~\"$backend\", status=~\"5..\"}[5m])) by (backend) / sum(rate(stoa_api_proxy_requests_total{backend=~\"$backend\"}[5m])) by (backend)",
          "legendFormat": "{{ backend }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Circuit Breaker Opens (by backend)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "pointSize": 5,
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(increase(stoa_api_proxy_circuit_open_total{backend=~\"$backend\"}[5m])) by (backend)",
          "legendFormat": "{{ backend }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Rate Limited Requests (by backend)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 30,
            "pointSize": 5,
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(increase(stoa_api_proxy_rate_limited_total{backend=~\"$backend\"}[5m])) by (backend)",
          "legendFormat": "{{ backend }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Duration Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": { "scheme": "Oranges", "steps": 64 },
        "tooltip": { "show": true }
      },
      "targets": [
        {
          "expr": "sum(increase(stoa_api_proxy_duration_seconds_bucket{backend=~\"$backend\"}[5m])) by (le)",
          "legendFormat": "{{ le }}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["stoa", "api-proxy", "dogfooding"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(stoa_api_proxy_requests_total, backend)",
        "includeAll": true,
        "multi": true,
        "name": "backend",
        "query": { "query": "label_values(stoa_api_proxy_requests_total, backend)", "refId": "A" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "STOA API Proxy Traffic",
  "uid": "stoa-dogfooding",
  "version": 1
}
