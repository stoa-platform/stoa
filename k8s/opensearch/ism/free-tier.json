{
  "policy": {
    "description": "STOA Free tier: 1d hot, delete after 7d, rollover at 5GB",
    "default_state": "hot",
    "ism_template": [
      { "index_patterns": ["stoa-*-free-*"], "priority": 100 }
    ],
    "states": [
      {
        "name": "hot",
        "actions": [
          {
            "rollover": {
              "min_size": "5gb",
              "min_index_age": "1d"
            }
          }
        ],
        "transitions": [
          { "state_name": "delete", "conditions": { "min_index_age": "7d" } }
        ]
      },
      {
        "name": "delete",
        "actions": [
          { "delete": {} }
        ],
        "transitions": []
      }
    ]
  }
}
