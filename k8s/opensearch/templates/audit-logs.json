{
  "index_patterns": ["stoa-audit-*"],
  "priority": 100,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1,
      "index.plugins.index_state_management.rollover_alias": "stoa-audit"
    },
    "mappings": {
      "_meta": {
        "schema_version": 1,
        "managed_by": "stoa-platform",
        "ticket": "CAB-1684"
      },
      "dynamic": "strict",
      "properties": {
        "timestamp": { "type": "date" },
        "tenant_id": { "type": "keyword" },
        "actor": { "type": "keyword" },
        "action": { "type": "keyword" },
        "resource": { "type": "keyword" },
        "detail": { "type": "text" }
      }
    }
  }
}
