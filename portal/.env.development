# Developer Portal — Local development (loaded automatically by Vite in dev mode)
# Matches docker-compose defaults from deploy/docker-compose/

VITE_ENVIRONMENT=dev
VITE_API_URL=http://localhost:8000
VITE_MCP_URL=http://localhost:8081
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=stoa
VITE_KEYCLOAK_CLIENT_ID=stoa-portal
VITE_ENABLE_DEBUG=true
