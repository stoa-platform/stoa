# Developer Portal — Environment Configuration
# Copy this file to .env.local and fill in your values
# Vite requires VITE_ prefix for all client-side env vars
# See src/config.ts for all available settings

# ── Core ─────────────────────────────────────────────────────────────────────
# VITE_BASE_DOMAIN=gostoa.dev             # Used to construct default URLs
# VITE_ENVIRONMENT=dev                    # dev | staging | production

# ── API ──────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_MCP_URL=http://localhost:8080
# VITE_API_TIMEOUT=30000                  # ms
# VITE_MCP_TIMEOUT=30000                  # ms

# ── Keycloak Authentication ──────────────────────────────────────────────────
VITE_KEYCLOAK_URL=http://localhost:8280
# VITE_KEYCLOAK_REALM=stoa
# VITE_KEYCLOAK_CLIENT_ID=stoa-portal     # Different from Console UI

# ── Feature Flags ────────────────────────────────────────────────────────────
# VITE_ENABLE_MCP_TOOLS=true
# VITE_ENABLE_SUBSCRIPTIONS=true
# VITE_ENABLE_API_CATALOG=true
# VITE_ENABLE_APPLICATIONS=true
# VITE_ENABLE_API_TESTING=true
# VITE_ENABLE_GATEWAYS=true
# VITE_ENABLE_DEBUG=false

# ── Testing ──────────────────────────────────────────────────────────────────
# VITE_AVAILABLE_ENVIRONMENTS=prod        # Comma-separated: dev,staging,prod
# VITE_REQUIRE_SANDBOX_CONFIRMATION=false

# ── UI ───────────────────────────────────────────────────────────────────────
# VITE_ITEMS_PER_PAGE=20
# VITE_REFRESH_INTERVAL=30000             # ms
