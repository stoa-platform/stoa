{
  "name": "STOA AI Factory — /stoa Slash Command",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "stoa-slash-command",
        "responseMode": "lastNode",
        "options": {
          "rawBody": true
        }
      },
      "id": "slash-webhook",
      "name": "Slash Command Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 300],
      "webhookId": "stoa-slash-command"
    },
    {
      "parameters": {
        "jsCode": "// Validate Slack signature + parse /stoa command + check access tier\nconst crypto = require('crypto');\n\nconst headers = $input.first().json.headers;\nconst rawBody = $input.first().json.body;\nconst signature = headers['x-slack-signature'];\nconst timestamp = headers['x-slack-request-timestamp'];\n\n// --- Signature validation ---\nconst signingSecret = $env.SLACK_SIGNING_SECRET;\nif (!signingSecret) {\n  throw new Error('SLACK_SIGNING_SECRET not configured');\n}\n\nconst now = Math.floor(Date.now() / 1000);\nif (Math.abs(now - parseInt(timestamp, 10)) > 300) {\n  throw new Error('Request timestamp too old — possible replay attack');\n}\n\nconst sigBasestring = `v0:${timestamp}:${rawBody}`;\nconst expected = 'v0=' + crypto.createHmac('sha256', signingSecret)\n  .update(sigBasestring)\n  .digest('hex');\n\nif (!crypto.timingSafeEqual(Buffer.from(signature), Buffer.from(expected))) {\n  throw new Error('Invalid Slack signature');\n}\n\n// --- Parse command ---\nconst params = new URLSearchParams(rawBody);\nconst text = (params.get('text') || '').trim();\nconst userId = params.get('user_id') || '';\nconst userName = params.get('user_name') || '';\nconst responseUrl = params.get('response_url') || '';\n\nconst parts = text.split(/\\s+/);\nconst command = (parts[0] || 'help').toLowerCase();\nconst arg = parts.slice(1).join(' ');\n\n// --- Access tier ---\nconst adminUsers = ($env.SLACK_ADMIN_USERS || '')\n  .split(',').map(s => s.trim()).filter(Boolean);\nconst allowedUsers = ($env.SLACK_ALLOWED_USERS || '')\n  .split(',').map(s => s.trim()).filter(Boolean);\n\nlet tier = 'readonly';\nif (adminUsers.length > 0 && adminUsers.includes(userId)) {\n  tier = 'admin';\n} else if (adminUsers.length === 0 && allowedUsers.length > 0 && allowedUsers.includes(userId)) {\n  tier = 'admin';\n} else if (allowedUsers.includes(userId)) {\n  tier = 'allowed';\n}\nif (tier === 'readonly') {\n  if (allowedUsers.length > 0) {\n    throw new Error(`User ${userId} not authorized`);\n  }\n  tier = 'admin';\n}\n\nreturn [{ json: { command, arg, userId, userName, responseUrl, tier } }];"
      },
