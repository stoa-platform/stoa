    {
      "parameters": {
        "jsCode": "const runs = $input.first().json.workflow_runs || [];\nconst lines = runs.map(r => {\n  const emoji = r.conclusion === 'success' ? ':white_check_mark:' : ':x:';\n  const date = new Date(r.updated_at).toISOString().slice(0, 16).replace('T', ' ');\n  return `${emoji} *${r.name}* — ${r.conclusion} (${date})`;\n});\n\nconst text = lines.length > 0\n  ? `:satellite_antenna: *Recent Workflow Runs*\\n${lines.join('\\n')}`\n  : ':satellite_antenna: No recent workflow runs found.';\n\nconst responseUrl = $('Validate & Parse').first().json.responseUrl;\n\nreturn [{ json: { text, responseUrl } }];"
      },
