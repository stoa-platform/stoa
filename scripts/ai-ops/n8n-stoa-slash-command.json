        "specifyBody": "json",
        "jsonBody": "={ \"event_type\": \"linear-ticket-started\", \"client_payload\": { \"ticket_id\": \"{{ $json.ticketId }}\", \"ticket_title\": \"Dispatched via /stoa\", \"ticket_description\": \"Triggered from Slack by {{ $json.userName }}\", \"priority\": 2, \"estimate\": 5 } }",
        "options": {}
