    {
      "parameters": {
        "jsCode": "// Admin-only check + validate ticket format\nif ($input.first().json.tier !== 'admin') {\n  throw new Error('Implement requires admin tier');\n}\nconst arg = $input.first().json.arg || '';\nconst match = arg.match(/^(CAB-\\d+)$/i);\nif (!match) {\n  throw new Error(`Invalid ticket format: \"${arg}\". Expected: CAB-XXXX`);\n}\nconst ticketId = match[1].toUpperCase();\nreturn [{ json: { ...$input.first().json, ticketId } }];"
      },
