#!/bin/bash
# stoa-parallel — Launch parallel Claude Code tmux workspace (CAB-1513 v2)
#
# Layout (7 panes in 1 window — tiled grid, all visible):
#   Pane 0: ORCHESTRE  — Lead orchestrator (always Max, full repo access)
#   Pane 1: MONITOR    — htop + memory watchdog
#   Pane 2: BACKEND    — Claude (control-plane-api, infra, docs)
#   Pane 3: FRONTEND   — Claude (portal, control-plane-ui, shared)
#   Pane 4: AUTH       — Claude (keycloak, IAM, OAuth)
#   Pane 5: MCP        — Claude (stoa-gateway, Rust)
#   Pane 6: QA         — Claude (e2e, tests — read-only on rest)
#
# Pane borders show role names. Zoom any pane: Ctrl+B z (toggle).
#
# Shared state: PocketBase (state.gostoa.dev) via heg-state CLI.
# Each instance runs `heg-state start` at startup to register session + claim.
# ORCHESTRE uses `heg-state remote-ls` for cross-instance visibility.
#
# Billing modes:
#   - Max (subscription): ORCHESTRE + BACKEND + MCP (heaviest workloads)
#   - API (consumption):  FRONTEND + AUTH + QA (lighter scopes)
#
# API key resolution (in order):
#   1. --api-key=sk-ant-...              explicit
#   2. ANTHROPIC_API_KEY env var         from .zshrc or shell
#   3. Infisical vault (auto-fetched)    vault.gostoa.dev/prod/anthropic
#
# Usage:
#   stoa-parallel                          # auto-fetch key → 3 Max + 3 API
#   stoa-parallel --api-key=sk-ant-...     # explicit key → 3 Max + 3 API
#   stoa-parallel --max-panes=0,2,5        # Override which panes use Max
#   stoa-parallel --all-api                # All on API key
#   stoa-parallel --all-max                # All on Max (no API key needed)
#   stoa-parallel --attach                 # Create + attach
#   stoa-parallel --kill                   # Tear down
#   stoa-parallel --no-claude              # Layout only

set -euo pipefail

SESSION="stoa"
STOA_DIR="$HOME/hlfh-repos/stoa"
LAUNCH_CLAUDE=true
API_KEY="${ANTHROPIC_API_KEY:-}"
# Default: panes 0 (ORCHESTRE) and 2 (BACKEND) on Max — 2 Max + 4 API
MAX_PANES="0,2"
ALL_API=false
ALL_MAX=false

INFISICAL_API="${INFISICAL_API_URL:-https://vault.gostoa.dev/api}"
INFISICAL_PROJECT="97972ffc-990b-4d28-9c4d-0664d217f03b"

# Instance role context files (CLAUDE.local.md per role)
INSTANCES_DIR="$STOA_DIR/.claude/instances"

# Pane index → role name mapping
ROLES=(ORCHESTRE MONITOR BACKEND FRONTEND AUTH MCP QA)

# Fetch API key from Infisical if not already set
fetch_api_key() {
  if [[ -n "$API_KEY" || "$ALL_MAX" == "true" ]]; then return 0; fi

  echo "Fetching ANTHROPIC_API_KEY from Infisical..."
  local token
  token=$(infisical-token --raw 2>/dev/null) || {
    echo "WARN: Infisical auth failed — falling back to all-Max mode" >&2
    ALL_MAX=true
    return 0
  }

  local response
  response=$(curl -sf \
    "${INFISICAL_API}/v3/secrets/raw/ANTHROPIC_API_KEY?workspaceId=${INFISICAL_PROJECT}&environment=prod&secretPath=/anthropic" \
    -H "Authorization: Bearer ${token}" 2>/dev/null) || {
    echo "WARN: Secret not found in Infisical (prod/anthropic/ANTHROPIC_API_KEY)" >&2
    ALL_MAX=true
    return 0
  }

  API_KEY=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin)['secret']['secretValue'])" 2>/dev/null) || {
    echo "WARN: Could not parse Infisical response — falling back to all-Max mode" >&2
    ALL_MAX=true
    return 0
  }

  if [[ -z "$API_KEY" || "$API_KEY" == "null" ]]; then
    echo "WARN: Empty API key from Infisical — falling back to all-Max mode" >&2
    ALL_MAX=true
    return 0
  fi

  echo "OK: API key loaded from Infisical (${API_KEY:0:10}...)"
}

# Parse args
for arg in "$@"; do
  case "$arg" in
    --kill)
      echo "Killing session $SESSION..."
      tmux kill-session -t "$SESSION" 2>/dev/null || echo "No session to kill."
      # Cleanup generated files
      for role in orchestre backend frontend auth mcp qa; do
        rm -f "$INSTANCES_DIR/${role}.local.md"
      done
      rm -rf /tmp/claude-api-config
      exit 0
      ;;
    --no-claude) LAUNCH_CLAUDE=false ;;
    --attach) ;; # handled at the end
    --all-api) ALL_API=true ;;
    --all-max) ALL_MAX=true ;;
    --api-key=*) API_KEY="${arg#--api-key=}" ;;
    --max-panes=*) MAX_PANES="${arg#--max-panes=}" ;;
    --max-windows=*) MAX_PANES="${arg#--max-windows=}" ;; # compat alias
    -h|--help)
      cat <<'HELP'
Usage: stoa-parallel [OPTIONS]

Options:
  --attach              Create and attach immediately
  --kill                Kill existing session
  --no-claude           Create layout without launching Claude instances
  --api-key=sk-ant-...  Set API key for consumption-billed instances
  --max-panes=0,2,5     Pane indices that use Max subscription (default: 0,2,5)
  --all-api             All instances on API key (requires --api-key)
  --all-max             All instances on Max subscription
  -h, --help            Show this help

Navigation (7 panes in tiled grid):
  Ctrl+B q       Show pane numbers (then press digit to jump)
  Ctrl+B o       Cycle to next pane
  Ctrl+B z       Zoom/unzoom pane (fullscreen toggle)
  Ctrl+B ↑↓←→   Move between panes directionally
  Ctrl+B d       Detach (everything keeps running)
  tmux attach -t stoa   Reattach

Pane map:
  0 = ORCHESTRE   1 = MONITOR   2 = BACKEND
  3 = FRONTEND    4 = AUTH      5 = MCP       6 = QA

Cross-instance messaging:
  stoa-dispatch BACKEND "Travaille sur CAB-1350"
  stoa-dispatch --list     List panes
  stoa-dispatch --status   Show heg-state remote-ls

Instance → Linear label:
  BACKEND  → instance:backend   (control-plane-api, infra)
  FRONTEND → instance:frontend  (portal, control-plane-ui)
  AUTH     → instance:auth      (keycloak, IAM)
  MCP      → instance:mcp       (stoa-gateway)
  QA       → instance:qa        (e2e, tests)

Shared state: PocketBase (state.gostoa.dev) via heg-state CLI
HELP
      exit 0
      ;;
    --api-key)
      echo "Use --api-key=VALUE (with =)" >&2; exit 1
      ;;
  esac
done

# Auto-fetch API key from Infisical if needed
fetch_api_key

if tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "Session '$SESSION' already exists."
  echo "  tmux attach -t $SESSION     # attach"
  echo "  stoa-parallel --kill         # kill and restart"
  for arg in "$@"; do
    [[ "$arg" == "--attach" ]] && exec tmux attach -t "$SESSION"
  done
  exit 0
fi

# Determine billing mode per pane
is_max_pane() {
  local pane="$1"
  if [[ "$ALL_MAX" == "true" ]]; then return 0; fi
  if [[ "$ALL_API" == "true" ]]; then return 1; fi
  if [[ -z "$API_KEY" ]]; then return 0; fi  # no key = all Max
  echo ",$MAX_PANES," | grep -q ",$pane,"
}

# Pane index → instance role (lowercase)
pane_role() {
  case "$1" in
    2) echo "backend" ;;
    3) echo "frontend" ;;
    4) echo "auth" ;;
    5) echo "mcp" ;;
    6) echo "qa" ;;
  esac
}

# Generate CLAUDE.local.md context files for each role
generate_context_files() {
  mkdir -p "$INSTANCES_DIR"

  # ORCHESTRE context
  cat > "$INSTANCES_DIR/orchestre.local.md" << 'ORCHEOF'
# Instance: ORCHESTRE (Lead)

Tu es le LEAD ORCHESTRATEUR de la session stoa-parallel. Tu coordonnes 5 instances specialisees.

## Tes instances

| Pane | Role | Scope | Commande |
|------|------|-------|----------|
| 2 | BACKEND | control-plane-api/, charts/, k8s/ | `stoa-dispatch BACKEND "..."` |
| 3 | FRONTEND | portal/, control-plane-ui/, shared/ | `stoa-dispatch FRONTEND "..."` |
| 4 | AUTH | keycloak/, OAuth configs | `stoa-dispatch AUTH "..."` |
