```bash
# Voir toutes les sessions actives + claims
heg-state remote-ls

# Envoyer une instruction a une instance
stoa-dispatch BACKEND "Travaille sur CAB-1350: description courte"

# Demander le status
stoa-dispatch MCP "Quel est ton avancement ?"
```

