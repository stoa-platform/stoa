}

echo "Creating 7-pane tmux grid..."

# ── Create session with pane 0 (ORCHESTRE) ──
# Use -x/-y to ensure enough space for 7 panes when detached (resizes on attach)
tmux new-session -d -s "$SESSION" -n "workspace" -x 220 -y 60 -c "$STOA_DIR"

# ── Create panes 1-6 (apply tiled after each split to redistribute space) ──
PANE_DIRS=(
  "$STOA_DIR"                    # pane 1: MONITOR
  "$STOA_DIR/control-plane-api"  # pane 2: BACKEND
  "$STOA_DIR/portal"             # pane 3: FRONTEND
  "$STOA_DIR"                    # pane 4: AUTH
  "$STOA_DIR/stoa-gateway"       # pane 5: MCP
  "$STOA_DIR/e2e"                # pane 6: QA
)
for dir in "${PANE_DIRS[@]}"; do
  tmux split-window -t "$SESSION:workspace" -c "$dir"
  tmux select-layout -t "$SESSION:workspace" tiled
done

# ── Pane border labels (static, based on pane_index — immune to Claude Code overrides) ──
BORDER_FMT='#{?#{==:#{pane_index},0},ORCHESTRE,#{?#{==:#{pane_index},1},MONITOR,#{?#{==:#{pane_index},2},BACKEND,#{?#{==:#{pane_index},3},FRONTEND,#{?#{==:#{pane_index},4},AUTH,#{?#{==:#{pane_index},5},MCP,QA}}}}}}'
tmux set-window-option -t "$SESSION:workspace" pane-border-format " ${BORDER_FMT} "
tmux set-window-option -t "$SESSION:workspace" pane-border-status top
tmux set-window-option -t "$SESSION:workspace" allow-rename off

# ── Style: highlight active pane ──
tmux set-window-option -t "$SESSION:workspace" pane-active-border-style "fg=cyan,bold"
tmux set-window-option -t "$SESSION:workspace" pane-border-style "fg=colour240"

# ── Ensure homebrew PATH in all panes (tmux may not source .zprofile) ──
# Send PATH export and wait for shells to process it before launching any commands.
HOMEBREW_PATH="/opt/homebrew/bin:/opt/homebrew/sbin"
for p in 0 1 2 3 4 5 6; do
  tmux send-keys -t "$SESSION:workspace.$p" "export PATH=\"${HOMEBREW_PATH}:\$HOME/.local/bin:\$PATH\"" Enter
done

# Wait for all 7 shells to process the PATH export
sleep 2

# ── Launch MONITOR (pane 1): watchdog + GC ──
# Watchdog runs in background, GC runs in foreground (both infinite loops)
tmux send-keys -t "$SESSION:workspace.1" "claude-watchdog --threshold-gb 15 --system-gb 90 &" Enter
sleep 0.5
tmux send-keys -t "$SESSION:workspace.1" "stoa-exit-watchdog $SESSION &" Enter
sleep 0.5
tmux send-keys -t "$SESSION:workspace.1" "stoa-gc" Enter

if [[ "$LAUNCH_CLAUDE" == "true" ]]; then
  # ── Ensure auto-merge is enabled on the repo ──
  # Without this, `stoa-merge` and `gh pr merge --auto` fail silently.
  # Only check once per session (idempotent, non-blocking).
  auto_merge=$(gh api "repos/stoa-platform/stoa" --jq '.allow_auto_merge' 2>/dev/null || echo "unknown")
  if [[ "$auto_merge" == "false" ]]; then
    echo "Enabling auto-merge on stoa-platform/stoa..."
    gh api "repos/stoa-platform/stoa" -X PATCH -f allow_auto_merge=true >/dev/null 2>&1 || true
  elif [[ "$auto_merge" == "true" ]]; then
    echo "OK: Auto-merge already enabled"
  fi

  # Generate context files for each role
  generate_context_files

  # ── Prepare isolated config dir for API-key instances ──
  # CLAUDE_CONFIG_DIR overrides ~/.claude/ — API instances won't see Max credentials.
  # Max instances use default ~/.claude/ (with subscription credentials).
  #
  # Key insight: without .credentials.json, Claude Code doesn't see Max subscription
  # and falls back to ANTHROPIC_API_KEY env var → "API Usage Billing".
  #
  # We also pre-populate .claude.json with onboarding-complete flags so the
  # interactive first-time setup wizard (theme, account type, trust dialog,
  # etc.) is skipped entirely — navigating 5+ interactive screens via
  # `tmux send-keys` is fragile and breaks regularly.
  API_CONFIG_DIR="/tmp/claude-api-config"
  rm -rf "$API_CONFIG_DIR"
  mkdir -p "$API_CONFIG_DIR"
  # Symlink settings from REPO (not ~/.claude/) so API panes get:
  #   - Bash(*) permission (project settings.local.json)
  #   - Correct hooks (project settings.json: PreToolUse, PostToolUse, Stop)
  #   - MCP server config
  # Fallback to ~/.claude/ if repo files don't exist.
  if [[ -f "$STOA_DIR/.claude/settings.json" ]]; then
    ln -sf "$STOA_DIR/.claude/settings.json" "$API_CONFIG_DIR/settings.json"
  else
    ln -sf ~/.claude/settings.json "$API_CONFIG_DIR/settings.json" 2>/dev/null || true
  fi
  if [[ -f "$STOA_DIR/.claude/settings.local.json" ]]; then
    ln -sf "$STOA_DIR/.claude/settings.local.json" "$API_CONFIG_DIR/settings.local.json"
  else
    ln -sf ~/.claude/settings.local.json "$API_CONFIG_DIR/settings.local.json" 2>/dev/null || true
  fi
  cp -f ~/.claude/CLAUDE.md "$API_CONFIG_DIR/" 2>/dev/null || true
  # Symlink projects dir so session history and memory persist
  ln -sfn ~/.claude/projects "$API_CONFIG_DIR/projects" 2>/dev/null || true

  # Pre-populate .claude.json to skip the first-time setup wizard entirely.
  # Extract API key suffix for customApiKeyResponses (Claude stores last 20 chars).
  key_suffix="${API_KEY: -20}"
  cat > "$API_CONFIG_DIR/.claude.json" << CONFIGEOF
{
  "hasCompletedOnboarding": true,
  "lastOnboardingVersion": "2.1.59",
  "numStartups": 1,
  "effortCalloutDismissed": true,
  "lastReleaseNotesSeen": "2.1.59",
  "penguinModeOrgEnabled": true,
  "opusProMigrationComplete": true,
  "sonnet1m45MigrationComplete": true,
  "officialMarketplaceAutoInstallAttempted": true,
  "officialMarketplaceAutoInstalled": true,
  "customApiKeyResponses": {
    "approved": ["${key_suffix}"],
    "rejected": []
  },
  "projects": {
    "${STOA_DIR}": {
      "hasTrustDialogAccepted": true,
      "allowedTools": [],
      "mcpContextUris": [],
      "mcpServers": {},
      "enabledMcpjsonServers": [],
      "disabledMcpjsonServers": [],
      "projectOnboardingSeenCount": 0,
      "hasClaudeMdExternalIncludesApproved": false,
      "hasClaudeMdExternalIncludesWarningShown": false
    },
    "${STOA_DIR}/control-plane-api": {
      "hasTrustDialogAccepted": true,
      "allowedTools": [],
      "mcpContextUris": [],
      "mcpServers": {}
    },
    "${STOA_DIR}/portal": {
      "hasTrustDialogAccepted": true,
      "allowedTools": [],
      "mcpContextUris": [],
      "mcpServers": {}
    },
    "${STOA_DIR}/stoa-gateway": {
      "hasTrustDialogAccepted": true,
      "allowedTools": [],
      "mcpContextUris": [],
      "mcpServers": {}
    },
    "${STOA_DIR}/e2e": {
      "hasTrustDialogAccepted": true,
      "allowedTools": [],
      "mcpContextUris": [],
      "mcpServers": {}
    }
  }
}
CONFIGEOF

  # Count billing
  max_count=0; api_count=0
  for p in 0 2 3 4 5 6; do
    if is_max_pane "$p"; then max_count=$((max_count + 1)); else api_count=$((api_count + 1)); fi
  done
  echo "Launching 6 Claude instances (${max_count} Max + ${api_count} API)..."

  # ── ORCHESTRE (pane 0, always Max) ──
  tmux send-keys -t "$SESSION:workspace.0" "claude" Enter

  # ── Specialist instances (panes 2-6) ──
  for p in 2 3 4 5 6; do
    role=$(pane_role "$p")

    if is_max_pane "$p"; then
      # Max pane: uses ~/.claude/ (has subscription credentials)
      tmux send-keys -t "$SESSION:workspace.$p" "export STOA_INSTANCE=${role}" Enter
    else
      # API pane: CLAUDE_CONFIG_DIR points to dir WITHOUT Max credentials
      tmux send-keys -t "$SESSION:workspace.$p" "export STOA_INSTANCE=${role} ANTHROPIC_API_KEY='${API_KEY}' CLAUDE_CONFIG_DIR='${API_CONFIG_DIR}'" Enter
    fi
    # Small delay to ensure env export is processed before claude launch
    sleep 0.3
    # bypassPermissions: skips interactive prompts BUT keeps PreToolUse hooks
    # (pre-instance-scope.sh enforces the deny matrix — that's the real safety layer)
    tmux send-keys -t "$SESSION:workspace.$p" "claude --permission-mode bypassPermissions" Enter
  done
fi

# Focus on ORCHESTRE pane (pane 0)
tmux select-pane -t "$SESSION:workspace.0"

echo ""
echo "Session ready (7 panes, tiled grid):"
