{
  "name": "@stoa/shared",
  "version": "0.1.0",
  "private": true,
  "description": "STOA Design System - Shared components and utilities",
  "main": "index.ts",
  "scripts": {
    "generate:api-types": "openapi-typescript ../control-plane-api/openapi-snapshot.json -o api-types/generated.ts && node scripts/inject-tsnocheck.mjs api-types/generated.ts",
    "check:api-types": "openapi-typescript ../control-plane-api/openapi-snapshot.json -o /tmp/stoa-api-types-check.ts && node scripts/inject-tsnocheck.mjs /tmp/stoa-api-types-check.ts && diff -q api-types/generated.ts /tmp/stoa-api-types-check.ts"
  },
  "peerDependencies": {
    "lucide-react": "^0.300.0 || ^0.475.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "lucide-react": "^0.475.0",
    "openapi-typescript": "^7.13.0"
  }
}
