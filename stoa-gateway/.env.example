# STOA Gateway (Rust) — Environment Configuration
# Copy this file to .env and fill in your values
# All vars use STOA_ prefix (loaded via Figment)
# See src/config.rs for all available settings

# ── Server ───────────────────────────────────────────────────────────────────
# STOA_PORT=8080
# STOA_HOST=0.0.0.0
# STOA_ENVIRONMENT=dev                    # dev | staging | prod
# STOA_GATEWAY_MODE=edge-mcp             # edge-mcp | sidecar | proxy | shadow

# ── Authentication ───────────────────────────────────────────────────────────
# STOA_KEYCLOAK_URL=http://localhost:8280
# STOA_KEYCLOAK_REALM=stoa
# STOA_KEYCLOAK_CLIENT_ID=stoa-gateway
# STOA_KEYCLOAK_CLIENT_SECRET=
# STOA_KEYCLOAK_ADMIN_PASSWORD=           # For DCR public client patch (OAuth 2.1)
# STOA_JWT_SECRET=                        # Alternative to Keycloak (standalone mode)

# ── Control Plane ────────────────────────────────────────────────────────────
# STOA_CONTROL_PLANE_URL=http://localhost:8000
# STOA_CONTROL_PLANE_API_KEY=
# STOA_ADMIN_API_TOKEN=                   # Bearer token for admin API

# ── OAuth 2.1 / MCP ─────────────────────────────────────────────────────────
# STOA_GATEWAY_EXTERNAL_URL=http://localhost:8080  # Public URL (for OAuth discovery)
# STOA_MCP_SESSION_TTL_MINUTES=30

# ── Rate Limiting ────────────────────────────────────────────────────────────
# STOA_RATE_LIMIT_DEFAULT=1000
# STOA_RATE_LIMIT_WINDOW_SECONDS=60

# ── Quota Enforcement ────────────────────────────────────────────────────────
# STOA_QUOTA_ENFORCEMENT_ENABLED=false
# STOA_QUOTA_DEFAULT_RATE_PER_MINUTE=60
# STOA_QUOTA_DEFAULT_DAILY_LIMIT=10000

# ── Circuit Breaker ──────────────────────────────────────────────────────────
# STOA_CB_FAILURE_THRESHOLD=5
# STOA_CB_RESET_TIMEOUT_SECS=30
# STOA_CB_SUCCESS_THRESHOLD=2

# ── Guardrails ───────────────────────────────────────────────────────────────
# STOA_GUARDRAILS_PII_ENABLED=false
# STOA_GUARDRAILS_PII_REDACT=true
# STOA_GUARDRAILS_INJECTION_ENABLED=false

# ── Fallback Chain ───────────────────────────────────────────────────────────
# STOA_FALLBACK_ENABLED=false
# STOA_FALLBACK_CHAINS=                   # JSON: {"tool_a":["tool_a_v2","tool_a_readonly"]}
# STOA_FALLBACK_TIMEOUT_MS=5000

# ── Policy Engine ────────────────────────────────────────────────────────────
# STOA_POLICY_ENABLED=true
# STOA_POLICY_PATH=                       # Path to Rego policy file

# ── Observability ────────────────────────────────────────────────────────────
# STOA_LOG_LEVEL=info                     # trace | debug | info | warn | error
# STOA_LOG_FORMAT=json                    # json | text
# STOA_ACCESS_LOG_ENABLED=true
# STOA_OTEL_ENDPOINT=                     # OpenTelemetry collector URL

# ── Kafka Metering (optional, requires --features kafka) ─────────────────────
# STOA_KAFKA_ENABLED=false
# STOA_KAFKA_BROKERS=redpanda:9092
# STOA_KAFKA_METERING_TOPIC=stoa.metering
# STOA_KAFKA_ERRORS_TOPIC=stoa.errors

# ── K8s CRD Watcher (optional, requires --features k8s) ─────────────────────
# STOA_K8S_ENABLED=false

# ── Auto-Registration (ADR-028) ─────────────────────────────────────────────
# STOA_AUTO_REGISTER=true
# STOA_HEARTBEAT_INTERVAL_SECS=30

# ── mTLS (CAB-864, advanced) ────────────────────────────────────────────────
# STOA_MTLS_ENABLED=false
# STOA_MTLS_REQUIRE_BINDING=true
