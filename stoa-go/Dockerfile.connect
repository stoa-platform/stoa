FROM golang:1.22-alpine AS builder

RUN apk add --no-cache git ca-certificates

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags "-s -w -X main.Version=dev -X main.Commit=$(git rev-parse --short HEAD 2>/dev/null || echo none)" \
    -o /stoa-connect ./cmd/stoa-connect

FROM alpine:3.19
RUN apk add --no-cache ca-certificates curl
COPY --from=builder /stoa-connect /usr/local/bin/stoa-connect
ENTRYPOINT ["/usr/local/bin/stoa-connect"]
